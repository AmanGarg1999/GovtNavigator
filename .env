# Postgres Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=govt_navigator

# Backend Configuration
PROJECT_NAME="GovtNavigator API"
DATABASE_URL=postgresql://postgres:postgres@db:5432/govt_navigator

# LLM Configuration (Ollama)
# If Ollama is running on the host Mac/Windows, use host.docker.internal
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_INTERPRETER_MODEL=mistral:latest
OLLAMA_ANALYZER_MODEL=llama3:8b
